<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller= "Controllers.AfficherArticle">


   <VBox xmlns:fx="http://javafx.com/fxml" >
      <TableView fx:id="articlesTable">
         <columns>
            <TableColumn text="ID" fx:id="idColumn"/>
            <TableColumn text="Entite ID" fx:id="entiteIdColumn"/>
            <TableColumn text="Title" fx:id="titleColumn"/>
            <TableColumn text="Description" fx:id="descriptionColumn"/>
            <TableColumn text="Content" fx:id="contentColumn"/>
            <TableColumn text="Creation Date" fx:id="dateColumn"/>
         </columns>
      </TableView>
   </VBox>

</AnchorPane>
